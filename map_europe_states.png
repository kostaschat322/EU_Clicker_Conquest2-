_modal_title_3\":\"Τριμηνιαίος\",\"select_plan_trial_modal_title_half_yearly\":\"Εξαμηνιαία\",\"select_plan_current_plan\":\"Ρεύμα\",\"select_plan_power_plan_title\":\"Power\",\"select_plan_popular\":\"Δημοφιλής\",\"select_plan_save\":\"Εξοικονομήστε {amount}\",\"subscription_downgrade_success_toast\":\"Το πρόγραμμά σας έχει ενημερωθεί. Οι αλλαγές θα τεθούν σε ισχύ στο τέλος της τρέχουσας περιόδου χρέωσης.\",\"subscription_downgrade_success_toast_2\":\"Το πρόγραμμά σας θα αλλάξει σε μηνιαίο στις {date}. Χωρίς χρέωση σήμερα.\",\"subscription_plan_update_scheduled\":\"Το πλάνο σας θα ενημερωθεί στις {date} σε {plan}\",\"subscription_upgrade_plan_title_variant\":\"Ξεκλειδώστε τα όρια. Αναβαθμίστε τώρα. Κάντε αναβάθμιση.\",\"subscription_update_failed\":\"Αποτυχία ενημέρωσης συνδρομής. Παρακαλώ δοκιμάστε ξανά ή επικοινωνήστε με την υποστήριξη.\",\"scheduled_change_description\":\"Το πλάνο σας έχει προγραμματιστεί να αλλάξει σε {targetPlan} στις {date},\\nόταν ολοκληρωθεί η τρέχουσα περίοδος χρέωσής σας {currentPlan}.\",\"scheduled_change_stay_on_plan\":\"Παραμονή σε {plan}\",\"scheduled_change_cancelling\":\"Ακύρωση...\",\"scheduled_change_cancel_success_toast\":\"Η προγραμματισμένη υποβάθμιση ακυρώθηκε.\\nΘα παραμείνετε στο πρόγραμμα {plan}.\",\"scheduled_change_view_other_plans\":\"Δείτε άλλα πλάνα\",\"scheduled_change_plan_update_info\":\"Το πλάνο σας θα αλλάξει σε {targetPlan} στις {date}, όταν λήξει η τρέχουσα περίοδος χρέωσης.\",\"scheduled_change_no_charge_info\":\"Σήμερα δεν θα εφαρμοστεί χρέωση. Η επόμενη ημερομηνία χρέωσης είναι {date} για {amount}.\",\"downgrade_no_charge_today\":\"Χωρίς χρέωση σήμερα. Το πρόγραμμά σας θα αλλάξει σε {plan} στις {date} με χρέωση {amount}.\",\"scheduled_change_plan_name_half_yearly\":\"Εξαμηνιαίος\",\"scheduled_change_plan_name_six_months\":\"6 Μήνες\"},\"Chat\":{\"label_upgrade_plan\":\"Πρόγραμμα αναβάθμισης\",\"label_go_pro\":\"Αναβάθμιση σε PRO\",\"label_incognito_chat\":\"Συνομιλία incognito\",\"label_we_need_your_feedback\":\"Χρειαζόμαστε τα σχόλιά σας\",\"auth_signin_button\":\"Σύνδεση\",\"chat_error_initiating_chat\":\"Αποτυχία έναρξης συνομιλίας. Δοκιμάστε ξανά.\",\"too_many_streams_toast\":\"Περιμένετε να ολοκληρωθεί μία από τις άλλες συνομιλίες σας πριν ξεκινήσετε νέα.\",\"label_start_new\":\"Έναρξη νέας\",\"search_title\":\"Αναζήτηση\",\"search_placeholder\":\"Αναζήτηση συνομιλιών...\",\"search_loading\":\"Αναζήτηση...\",\"search_no_results\":\"Δεν βρέθηκαν συνομιλίες.\",\"search_no_recent\":\"Δεν υπάρχουν πρόσφατες συνομιλίες.\",\"search_results\":\"Αποτελέσματα\",\"search_untitled\":\"Συνομιλία χωρίς τίτλο\",\"label_error\":\"Σφάλμα\",\"unable_to_load_chat_messages\":\"Δεν είναι δυνατή η φόρτωση μηνυμάτων συνομιλίας. Δοκιμάστε ξανά.\",\"unable_to_connect\":\"Δεν είναι δυνατή η σύνδεση\",\"unable_to_connect_description\":\"Δεν ήταν δυνατή η φόρτωση της συνομιλίας σας. Ελέγξτε τη σύνδεσή σας στο διαδίκτυο και δοκιμάστε ξανά.\",\"conversation_placeholder\":\"Η συνομιλία σας θα εμφανιστεί εδώ\",\"try_again\":\"Δοκιμάστε ξανά\",\"reload_page\":\"Επαναφόρτωση σελίδας\",\"something_went_wrong_loading_chat\":\"Παρουσιάστηκε κάποιο πρόβλημα κατά τη φόρτωση της συνομιλίας. Δοκιμάστε να ανανεώσετε τη σελίδα ή επικοινωνήστε με την υποστήριξη εάν το πρόβλημα επιμένει.\",\"chat_greeting_hello\":\"Γεια σας!\",\"chat_greeting_good_morning\":\"Καλημέρα!\",\"chat_greeting_good_afternoon\":\"Καλημέρα!\",\"chat_greeting_good_evening\":\"Καλησπέρα!\",\"chat_greeting_hello_name\":\"Γεια σου, {name}!\",\"chat_greeting_good_morning_name\":\"Καλημέρα, {name}\",\"chat_greeting_good_afternoon_name\":\"Καλησπέρα, {name}\",\"chat_greeting_good_evening_name\":\"Καλησπέρα, {name}\",\"chat_greeting_help\":\"Πώς μπορώ να σας βοηθήσω σήμερα;\",\"chat_input_placeholder\":\"Πληκτρολογήστε ένα μήνυμα...\",\"chat_input_placeholder_experiment\":\"Ρωτήστε οτιδήποτε...\",\"button_tooltip_stop_generation\":\"Διακοπή δημιουργίας\",\"button_tooltip_input_length_exceeded\":\"Το μήνυμα είναι πολύ μεγάλο\",\"error_something_wrong\":\"Κάτι πήγε στραβά. Εάν το πρόβλημα επιμένει, επικοινωνήστε μαζί μας μέσω του κέντρου βοήθειας στη διεύθυνση\",\"error_something_wrong_retry\":\"Κάτι πήγε στραβά. Παρακαλώ δοκιμάστε ξανά.\",\"retry\":\"Δοκιμάστε ξανά\",\"refresh\":\"Ανανέωση\",\"checking\":\"Έλεγχος...\",\"research_still_running\":\"Η έρευνα εξακολουθεί να εκτελείται στο παρασκήνιο. Παρακαλώ περιμένετε ή ανανεώστε τη σελίδα.\",\"research_completed_refresh\":\"Η έρευνα ολοκληρώθηκε! Η σελίδα ανανεώνεται για να εμφανίσει τα αποτελέσματα...\",\"thinking\":\"Σκέφτομαι...\",\"tooltip_copy_to_clipboard\":\"Αντιγραφή στο πρόχειρο\",\"tooltip_upvote\":\"Ψηφίστε θετικά\",\"tooltip_downvote\":\"Αρνητική ψήφος\",\"tooltip_download_pdf\":\"Λήψη ως PDF\",\"tooltip_incognito_on\":\"Ενεργοποίηση ανώνυμης συνομιλίας\",\"tooltip_incognito_off\":\"Απενεργοποίηση ανώνυμης συνομιλίας\",\"toast_title_no_text_to_copy\":\"Δεν υπάρχει κείμενο για αντιγραφή!\",\"toast_description_no_text_to_copy\":\"Δεν υπάρχει κείμενο σε αυτή τη συνομιλία\",\"toast_copied_to_clipboard\":\"Αντιγράφηκε στο πρόχειρο\",\"toast_chat_copied_to_clipboard\":\"Ολόκληρο το κείμενο της συνομιλίας αντιγράφηκε στο πρόχειρο\",\"toast_web_search_copied\":\"Τα αποτελέσματα αναζήτησης ιστού αντιγράφηκαν στο πρόχειρο\",\"toast_deep_research_copied\":\"Τα αποτελέσματα εις βάθος έρευνας αντιγράφηκαν στο πρόχειρο\",\"message_editor_cancel\":\"Ματαίωση\",\"message_editor_sending\":\"Αποστολή...\",\"message_editor_send\":\"Στέλνω\",\"label_reasoning\":\"Αιτιολογία...\",\"label_reasoning_done\":\"Αιτιολογημένο για λίγα δευτερόλεπτα\",\"model_selector_placeholder\":\"Επιλέξτε μοντέλο\",\"chat_delete_success\":\"Η συνομιλία διαγράφηκε με επιτυχία.\",\"chat_delete_error\":\"Η διαγραφή της συνομιλίας απέτυχε. Δοκιμάστε ξανά.\",\"chat_rename_modal_title\":\"Μετονομασία συνομιλίας\",\"project_rename_modal_title\":\"Μετονομασία έργου\",\"toast_description_chat_rename_error\":\"Η μετονομασία της συζήτησης απέτυχε. Δοκιμάστε ξανά.\",\"btn_rename\":\"Μετονομασία