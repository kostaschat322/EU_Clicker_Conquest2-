",\"tool_read_event\":\"Ανάγνωση συμβάντος\",\"tool_search_events\":\"Αναζήτηση συμβάντων\",\"tool_create_event\":\"Δημιουργία συμβάντος\",\"tool_update_event\":\"Ενημέρωση συμβάντος\"}},\"ToolCall\":{\"common\":{\"show_less\":\"Εμφάνιση λιγότερων\",\"show_more\":\"Εμφάνιση περισσότερων\",\"searching\":\"Αναζήτηση...\",\"searching_for\":\"Αναζήτηση \\\"{query}\\\"\",\"running\":\"Εκτέλεση...\",\"no_response\":\"Χωρίς απόκριση\",\"no_response_timed\":\"Χωρίς απόκριση ({seconds}s)\",\"no_response_after_seconds\":\"Χωρίς απόκριση μετά από {seconds}s\",\"search_completed\":\"Η αναζήτηση ολοκληρώθηκε\",\"executing\":\"Εκτέλεση εργαλείου...\",\"no_details\":\"Δεν υπάρχουν διαθέσιμες λεπτομέρειες εργαλείου.\",\"failed\":\"Το {name} απέτυχε να εκτελεστεί.\",\"failed_short\":\"Το {name} απέτυχε.\",\"timed_out\":\"Το {name} δεν απάντησε μετά από {seconds}s.\",\"did_not_respond\":\"Το {name} δεν απάντησε.\",\"output\":\"Έξοδος\",\"hide_data\":\"Απόκρυψη δεδομένων\",\"view_full_data\":\"Προβολή πλήρων δεδομένων\",\"show_all_results_one\":\"Εμφάνιση {count} αποτελέσματος\",\"show_all_results_other\":\"Εμφάνιση {count} αποτελεσμάτων\",\"status_running\":\"Εκτέλεση...\",\"status_no_response\":\"Χωρίς απόκριση ({seconds}s)\",\"status_failed\":\"Αποτυχία\",\"status_error\":\"Σφάλμα\",\"status_success\":\"Επιτυχία\",\"status_done\":\"Ολοκληρώθηκε\",\"source_count_one\":\"{count} πηγή\",\"source_count_other\":\"{count} πηγές\"},\"webSearch\":{\"toolkit_title\":\"Αναζήτηση στο διαδίκτυο\",\"idle\":\"Αναζήτηση στο διαδίκτυο ολοκληρώθηκε\",\"idle_stopped\":\"Η αναζήτηση στο διαδίκτυο διακόπηκε\",\"idle_failed\":\"Η αναζήτηση στο διαδίκτυο απέτυχε\",\"loading\":\"Αναζήτηση στο διαδίκτυο\",\"entry_fallback\":\"Αναζήτηση στο διαδίκτυο\",\"entry_fallback_loading\":\"Αναζήτηση…\",\"show_all_sources_one\":\"Εμφάνιση {count} πηγής\",\"show_all_sources_other\":\"Εμφάνιση {count} πηγών\",\"show_fewer\":\"Εμφάνιση λιγότερων\",\"source_count_one\":\"{count} πηγή\",\"source_count_other\":\"{count} π