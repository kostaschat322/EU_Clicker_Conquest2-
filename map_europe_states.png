_preview\":\"Προβολή σε πλήρη οθόνη\",\"preview_close\":\"Κοντά\",\"stopped\":\"Η δημιουργία εικόνας σταμάτησε. Μπορείτε να δημιουργήσετε νέα εικόνα πληκτρολογώντας την περιγραφή της εικόνας που χρειάζεστε\"},\"ReviewPrompt\":{\"title_enjoying\":\"Σας αρέσει το Use AI μέχρι τώρα;\",\"subtitle_rate\":\"Βαθμολογήστε το Use AI\",\"title_thanks\":\"Ευχαριστούμε!\",\"message_thanks\":\"Εκτιμούμε τα σχόλιά σας.\",\"title_awesome\":\"Φοβερό!\",\"message_share\":\"Θα χαρούμε πολύ αν μοιραστείτε την 5 αστέρων εμπειρία σας με άλλους!\",\"button_share\":\"Μοιράσου την 5‑άστερη εμπειρία μου\",\"button_no_help\":\"Δεν θέλω να βοηθήσω\",\"title_variant_b\":\"Θα χαρούμε να λάβουμε τα σχόλιά σας για το use.ai — μοιραστείτε την εμπειρία σας στο Trustpilot\",\"button_yes\":\"Ναι, με χαρά!\",\"button_no\":\"Όχι, όχι τώρα\"},\"TextareaTooltip\":{\"title_1\":\"Ξεκινήστε συνομιλία με AI\",\"description_1\":\"Ρωτήστε οτιδήποτε για έξυπνες απαντήσεις. Ανεβάστε και αναλύστε αρχεία, έγγραφα, PDF ή εικόνες\",\"button\":\"Ξεκινήστε τώρα\"},\"Deepsearch\":{\"objective_label\":\"Στόχος\",\"initiating_research\":\"Η βαθιά έρευνα ξεκινά\",\"starting_research\":\"Έναρξη έρευνας\",\"research_started\":\"Η έρευνα ξεκίνησε\",\"clarification_needed\":\"Απαιτείται διευκρίνιση\",\"research_complete\":\"Έρευνα ολοκληρώθηκε\",\"researching\":\"Έρευνα\",\"searching_the_web\":\"Αναζήτηση στον ιστό...\",\"starting_search\":\"Έναρξη αναζήτησης...\",\"reading_knowledge_base\":\"Ανάγνωση αρχείων από τη βάση γνώσεων\",\"researched_in\":\"Ερευνήθηκε σε\",\"sources\":\"Πηγές\",\"searches\":\"αναζητήσεις\",\"sources_found\":\"πηγές βρέθηκαν\",\"compiling_sources\":\"Συλλογή πηγών\",\"citations\":\"Παραπομπές\",\"references_heading\":\"Αναφορές\",\"executive_summary_heading\":\"Σύνοψη\",\"no_sources_found\":\"Δεν βρέθηκαν πηγές\",\"activity\":\"Δραστηριότητα\",\"sources_tab\":\"Πηγές\",\"close_sidebar\":\"Κλείσιμο πλευρικής γραμμής\",\"research_tabs\":\"Καρτέλες έρευνας\",\"research_progress\":\"Πρόοδος έρευνας\",\"writing_research_brief\":\"Συγγραφή περίληψης έρευνας\",\"research_brief_ready\":\"Η περίληψη έρευνας είναι έτοιμη\",\"conducting_research_on_topic\":\"Διεξαγωγή έρευνας για το θέμα\",\"conducting_research\":\"Διεξαγωγή έρευνας\",\"will_investigate\":\"Θα διερευνηθεί\",\"topic_plural\":\"θέμα(τα)\",\"research_topics_identified\":\"Προσδιορίστηκαν τα θέματα έρευνας\",\"research_topics_message\":\"Θα ερευνήσει {count} θέμα(τα): {topics}\",\"writing_final_report\":\"Συγγραφή τελικής αναφοράς\",\"research_timed_out\":\"Η έρευνα έληξε\",\"research_timeout\":\"Λήξη χρόνου έρευνας\",\"research_failed\":\"Η έρευνα απέτυχε\",\"research_cancelled\":\"Η έρευνα ακυρώθηκε\",\"research_was_cancelled\":\"Η έρευνα ακυρώθηκε\",\"research_already_in_progress\":\"Η έρευνα είναι ήδη σε εξέλιξη\",\"no_active_research_to_cancel\":\"Δεν υπάρχει ενεργή έρευνα για ακύρωση\",\"deep_research_failed_with_error\":\"Η βαθιά έρευνα απέτυχε με σφάλμα: {error}\",\"research_failed_to_start\":\"Η έρευνα δεν ξεκίνησε\",\"research_continues_in_background\":\"Η έρευνα συνεχίζεται στο παρασκήνιο\",\"research_ended_unexpectedly\":\"Η έρευνα τερματίστηκε απροσδόκητα\",\"searching_with_openrouter\":\"Αναζήτηση με OpenRouter\",\"searching\":\"Αναζήτηση\",\"searching_sources\":\"Αναζήτηση πηγών\",\"reading_sources\":\"Ανάγνωση {count} πηγών\",\"searching_with_exa\":\"Αναζήτηση με Exa\",\"exa_search_complete\":\"Αναζήτηση Exa ολοκληρώθηκε\",\"openrouter_search_complete\":\"Αναζήτηση OpenRouter ολοκληρώθηκε\",\"web_search_complete\":\"Η διαδικτυακή αναζήτηση ολοκληρώθηκε\",\"supervisor_evaluation_coordination\":\"Συντονισμός αξιολόγησης επόπτη\",\"completed_evaluation_of_investigation_efforts\":\"Η αξιολόγηση των προσπαθειών διερεύνησης ολοκληρώθηκε.\",\"research_in_progress\":\"Η έρευνα εξακολουθεί να βρίσκεται σε εξέλιξη. Ανανεώστε τη σελίδα για να δείτε τα αποτελέσματα όταν ολοκληρωθεί.\",\"stream_disconnected_but_research_is_still_running\":\"Η ροή αποσυνδέθηκε αλλά η έρευνα εξακολουθεί να εκτελείται. Ανανεώστε τη σελίδα για να δείτε τα αποτελέσματα.\",\"unable_to_verify_research_status\":\"Δεν ήταν δυνατή η επαλήθευση της κατάστασης έρευνας. Ανανεώστε τη σελίδα για να ελέγξετε τα αποτελέσματα.\",\"error_resuming_research_stream\":\"Δεν ήταν δυνατή η επανάληψη της ροής έρευνας. Ανανεώστε τη σελίδα για να ελέγξετε τα αποτελέσματα.\",\"analyzing_sources\":\"Ανάλυση πηγών\",\"analyzing_sources_message\":\"Βρέθηκαν {count} πηγές\",\"analyzing_request\":\"Ανάλυση αιτήματος\",\"extracting_insights\":\"Εξαγωγή ενδείξεων\",\"processing_content\":\"Επεξεργασία περιεχομένου από πηγές\",\"processing_research\":\"Επεξεργασία έρευνας\",\"summarizing_content\":\"Σύνοψη περιεχομένου\",\"generating_report\":\"Δημιουργία αναφοράς\",\"preparing_findings\":\"Προετοιμασία βασικών ευρημάτων\",\"generating_topic_research_summary\":\"Δημιουργία περίληψης έρευνας θέματος\",\"no_sources_found_for_search\":\"Δεν βρέθηκαν πηγές για αυτήν την αναζήτηση\",\"research_plan\":\"Αναγνώριση των κύριων λέξεων-κλειδιών για περιήγηση στο διαδίκτυο\",\"research_findings\":\"Ευρήματα έρευνας\",\"research_error\":\"Σφάλμα έρευνας\",\"found_new_pages\":\"Βρέθηκαν {newSourcesLength} νέες σελίδες\",\"report_complete\":\"Η αναφορά ολοκληρώθηκε\",\"research_summary_available\":\"Διαθέσιμη περίληψη έρευνας\"},\"LimitedOfferBanner\":{\"free_messages_expire\":\"Τα δωρεάν μηνύματά σας λήγουν σε {timeRemaining}\"},\"Profile\":{\"page_title\":\"Το προφίλ μου\",\"page_subtitle\":\"Διαχειριστείτε τις ρυθμίσεις και τις προτιμήσεις του προφίλ σας\",\"change_email_title\":\"Email\",\"change_name_title\":\"Πλήρες Όνομα\",\"theme_title\":\"Θέμα\",\"theme_light\":\"Φωτεινό\",\"theme_dark\":\"Σκοτεινό\",\"theme_system\":\"Σύστημα\",\"current_email_label\":\"Θα λάβετε ένα email με κωδικό επαλήθευσης για να επιβεβαιώσετε την αλλαγή\",\"your_current_email_label\":\"Το τρέχον email σας\",\"full_name_label\":\"Πλήρες όνομα\",\"new_email_label\":\"Νέο Email\",\"new_email_placeholder\":\"Εισάγετε τη νέα διεύθυνση email σας\",\"edit_btn\":\"Επεξεργασία\",\"update_btn\":\"Ενημέρωση\",\"enter_your_name_placeholder\":\"Εισάγετε το όνομά σας\",\"save_btn\":\"Αποθήκευση\",\"cancel_btn\":\"Ακύρωση\",\"updating\":\"Ενημέρωση...\",\"update_name_btn\":\"Επεξεργασία Ονόματος\",\"email_updated_success\":\"Το email ενημερώθηκε με επιτυχία\",\"name_updated_success\":\"Το όνομα ενημερώθηκε με επιτυχία\",\"danger_zone_title\":\"Ζώνη Κινδύνου\",\"danger_zone_description\":\"Μόλις διαγράψετε τον λογαριασμό σας, δεν υπάρχει επιστροφή. Παρακαλώ να είστε σίγουροι.\",\"delete_account_btn\":\"Διαγραφή Λογαριασμού\",\"delete_account_modal_title\":\"Διαγραφή Λογαριασμού\",\"delete_account_modal_description\":\"Είστε σίγουροι ότι θέλετε να διαγράψετε τον λογαριασμό σας; Αυτή η ενέργεια δεν μπορεί να αναιρεθεί. Όλα τα δεδομένα σας, συμπεριλαμβανομένου του ιστορικού συνομιλιών, θα διαγραφούν μόνιμα.\",\"delete_account_confirm\":\"Ναι, Διέγραψε τον Λογαριασμό Μου\",\"delete_account_cancel\":\"Ακύρωση\",\"delete_account_deleting\":\"Διαγραφή...\",\"verification_title\":\"Επαλήθευση\",\"verification_description\":\"Στείλαμε έναν κωδικό επαλήθευσης στο email σας. Παρακαλώ εισάγετε τον παρακάτω για να επιβεβαιώσετε την αλλαγή.\",\"verification_resend_in\":\"Αποστολή ξανά σε {time}\",\"verification_resend\":\"Αποστολή ξανά\",\"verification_verify_btn\":\"Επαλήθευση\",\"verification_cancel\":\"Ακύρωση\",\"verification_verifying\":\"Επαλήθευση...\",\"toast_email_verification_sent\":\"An email verification has been sent, please check your new email address to confirm the change.\",\"toast_email_change_failed\":\"Failed to change email\",\"toast_name_updated_success\":\"Your name has been updated successfully\",\"toast_name_update_failed\":\"Failed to update name\",\"validation_email_required\":\"Email is required\",\"validation_email_invalid\":\"Please enter a valid email address\",\"validation_name_required\":\"Name is required\",\"api_user_unauthorized\":\"Unauthorized\",\"api_user_email_required\":\"Email is required\",\"api_user_email_invalid_format\":\"Invalid email format\",\"api_user_email_already_in_use\":\"Email is already in use\",\"api_user_email_must_be_different\":\"New email must be different from current email\",\"api_user_email_update_failed\":\"Failed to update email\"},\"CheckEmail\":{\"title\":\"Ελέγξτε το email σας\",\"description\":\"Σας στείλαμε έναν ασφαλή σύνδεσμο σύνδεσης.\",\"description2\":\"Αν δεν το βλέπετε στα εισερχόμενά σας, ελέγξτε τον φάκελο ανεπιθύμητης αλληλογραφίας.\"},\"ProjectSettings\":{\"title\":\"Ρυθμίσεις Έργου\",\"btn_close\":\"Κλείσιμο\",\"label_project_name\":\"Όνομα έργου\",\"placeholder_project_name\":\"Ονομάστε το έργο σας\",\"label_instructions\":\"Οδηγίες\",\"placeholder_instructions\":\"π.χ. \\\"Απάντα στα ισπανικά. Κράτα τις απαντήσεις σύντομες και εστιασμένες.\\\"\",\"label_files\":\"Αρχεία\",\"btn_add\":\"Προσθήκη\",\"files_count_one\":\"1 αρχείο\",\"files_count_other\":\"{count} αρχεία\",\"empty_state_description\":\"Προσθέστε έγγραφα, αρχεία κώδικα, εικόνες και άλλα. Το \u003cbold\u003e{projectName}\u003c/bold\u003e μπορεί να έχει πρόσβαση στο περιεχόμενό τους όταν συνομιλείτε μέσα στο έργο.\",\"file_contents_not_accessible\":\"Τα περιεχόμενα αρχείων ενδέχεται να μην είναι προσβάσιμα\",\"column_created_at\":\"Δημιουργήθηκε στις\",\"column_size\":\"Μέγεθος\",\"btn_delete_project\":\"Διαγραφή έργου\",\"btn_save\":\"Ολοκληρώθηκε\",\"delete_confirm_title\":\"Διαγραφή έργου;\",\"delete_confirm_description\":\"Αυτό θα διαγράψει μόνιμα όλα τα αρχεία του έργου και τις συνομιλίες.\",\"delete_confirm_chats_hint\":\"Για να αποθηκεύσετε συνομιλίες, μετακινήστε τις στη λίστα συνομιλιών ή σε άλλο έργο πριν τη διαγραφή.\",\"btn_cancel\":\"Ακύρωση\",\"btn_delete\":\"Διαγραφή\",\"file_exists_title\":\"Το αρχείο υπάρχει ήδη\",\"file_exists_description\":\"Ένα αρχείο με το όνομα \u003cbold\u003e{fileName}\u003c/bold\u003e υπάρχει ήδη.\",\"btn_upload_anyway\":\"Μεταφόρτωση ούτως ή άλλως\",\"status_processing\":\"Επεξεργασία...\",\"status_failed\":\"Αποτυχία\"},\"ProjectHero\":{\"btn_add_files\":\"Προσθήκη αρχείων\",\"btn_project_settings\":\"Ρυθμίσεις έργου\"},\"PromptLanding\":{\"headline\":\"Ο \u003chighlight\u003e$10χιλ./μήνα χάρτης κλιμάκωσης\u003c/highlight\u003e σας είναι \\n μόλις μία AI προτροπή μακριά.\",\"authority_line\":\"Δοκιμάστε αυτή την προτροπή για να ξεκλειδώσετε άλλα 4 ισχυρά mega-prompt\",\"prompt\":\"$34\",\"expert_prompt\":\"$35\",\"try_this_prompt_now\":\"Δοκιμάστε αυτή την προτροπή τώρα\",\"prompt_info_label\":\"Αυτή η προτροπή παρέχει μαγικά αποτελέσματα όταν χρησιμοποιείται χωρίς επεξεργασία\"},\"ImageLanding\":{\"add_images_card_title\":\"Προσθήκη εικόνων\",\"add_images_card_subtitle\":\"έως 10 φωτογραφίες\",\"add_images_helper\":\"Προσθέστε έως 10 εικόνες ή ξεκινήστε από την αρχή\",\"prompt_what_to_generate\":\"Περιγράψτε οποιαδήποτε εικόνα θέλετε να δημιουργήσετε\",\"prompt_what_to_generate_v2\":\"Περιγράψτε την εικόνα που θέλετε να δημιουργήσετε ή ανεβάστε μια φωτογραφία και επεξεργαστείτε την με AI\",\"generate_image_from_reference\":\"εμπνευσμένη από την ανεβασμένη φωτογραφία αναφοράς\",\"generate_image_from_pasted_content\":\"Δημιούργησε μια εικόνα από το επικολλημένο περιεχόμενο:\",\"generate_image_prompt_prefix\":\"Δημιούργησε μια εικόνα με αυτή την περιγραφή: {description}\",\"generate_images_prompt_prefix\":\"Δημιούργησε {count} παραλλαγές με αυτήν την περιγραφή: {description}\",\"prompt_style_suffix\":\"Στυλ: {label}\",\"prompt_aspect_ratio\":\"Αναλογία διαστάσεων: {label}\",\"aspect_ratio_label\":\"Αναλογία\",\"style_label\":\"Στυλ\",\"style_none\":\"Καθόλου\",\"style_realistic\":\"Ρεαλιστικό\",\"style_cartoon\":\"Καρτούν\",\"style_3d\":\"3D Render\",\"style_anime\":\"Άνιμε\",\"style_digital_art\":\"Ψηφιακό\",\"style_abstract\":\"Αφηρημένο\",\"ratio_1_1\":\"1:1 (Τετράγωνο)\",\"ratio_4_3\":\"4:3 (Τυπικό)\",\"ratio_3_4\":\"3:4 (Πορτραίτο)\",\"ratio_16_9\":\"16:9 (Ευρύ)\",\"ratio_9_16\":\"9:16 (Κινητό)\",\"ratio_21_9\":\"21:9 (Υπερευρύ)\",\"variations_1\":\"1 εικόνα\",\"variations_2\":\"2 εικόνες\",\"variations_4\":\"4 εικόνες\",\"gallery_title\":\"Οι εικόνες μου\",\"gallery_loading\":\"Φόρτωση εικόνων...\",\"gallery_empty\":\"Δεν έχετε δημιουργήσει ακόμα εικόνες\",\"image_unavailable\":\"Η εικόνα δεν είναι διαθέσιμη\",\"try_style_title\":\"Δοκιμάστε ένα στυλ σε μια εικόνα\",\"discover_title\":\"Ανακαλύψτε κάτι νέο\",\"modal_subtitle\":\"Ανακαλύψτε κάτι νέο\",\"modal_recents\":\"Πρόσφατα\",\"modal_choose_photo\":\"Επιλέξτε μια νέα φωτογραφία\",\"modal_cancel\":\"Ακύρωση\",\"discover_prompt_cartoon\":\"Κάνε με χαρακτήρα κινουμένων σχεδίων\",\"discover_prompt_headshot\":\"Δημιούργησε μια επαγγελματική φωτογραφία πορτρέτου\",\"discover_prompt_pet_royalty\":\"Κάνε το κατοικίδιό μου να μοιάζει με βασιλικό πρόσωπο\",\"discover_prompt_superhero\":\"Πώς θα έμοιαζα ως υπερήρωας;\",\"discover_prompt_watercolor\":\"Μετάτρεψε τη φωτογραφία μου σε ακουαρέλα\",\"discover_prompt_action_figure\":\"Κάνε με φιγούρα δράσης\",\"style_prompt_realistic\":\"Μετέτρεψε τη μεταφορτωμένη φωτογραφία μου σε μια υπερρεαλιστική εικόνα υψηλής ευκρίνειας. Βελτίωσε τον φωτισμό, τις υφές και τις λεπτομέρειες ώστε να μοιάζει με επαγγελματικά τραβηγμένη φωτογραφία με τέλεια καθαρότητα, φυσικά χρώματα και κινηματογραφικό βάθος πεδίου.\",\"style_prompt_cartoon\":\"Μετέτρεψε τη μεταφορτωμένη φωτογραφία μου σε μια ζωντανή εικονογράφηση κινουμένων σχεδίων. Ξαναφαντάσου το θέμα με έντονα περιγράμματα, υπερβολικά χαρακτηριστικά, φωτεινά κορεσμένα χρώματα και ένα διασκεδαστικό στυλ animation παρόμοιο με σύγχρονες ταινίες κινουμένων σχεδίων.\",\"style_prompt_3d\":\"Μετέτρεψε τη μεταφορτωμένη φωτογραφία μου σε ένα υψηλής ποιότητας 3D render. Ξαναφαντάσου το θέμα ως ένα λεπτομερές τρισδιάστατο μοντέλο με λείες επιφάνειες, φωτισμό στούντιο, διακριτικές σκιές και μια γυαλισμένη τρισδιάστατη εμφάνιση σαν χαρακτήρας Pixar ή CGI.\",\"style_prompt_anime\":\"Μετέτρεψε τη μεταφορτωμένη φωτογραφία μου σε στυλ anime. Ξαναφαντάσου το θέμα με μεγάλα εκφραστικά μάτια, στιλιζαρισμένα μαλλιά, καθαρές γραμμές και τη χαρακτηριστική αισθητική του ιαπωνικού anime με δραματικό φωτισμό και ζωντανά χρώματα.\",\"style_prompt_digital_art\":\"Μετέτρεψε τη μεταφορτωμένη φωτογραφία μου σε ένα εκπληκτικό ψηφιακό έργο τέχνης. Ξαναφαντάσου το θέμα με δημιουργικές τεχνικές ψηφιακής ζωγραφικής, πλούσιες χρωματικές παλέτες, καλλιτεχνικές πινελιές και μια μοντέρνα αισθητική ψηφιακής εικονογράφησης.\",\"style_prompt_abstract\":\"Μετέτρεψε τη μεταφορτωμένη φωτογραφία μου σε ένα αφηρημένο έργο τέχνης. Ξαναφαντάσου το θέμα χρησιμοποιώντας γεωμετρικά σχήματα, τολμηρά μπλοκ χρωμάτων, σουρεαλιστικές συνθέσεις και καλλιτεχνική αφαίρεση, διατηρώντας αναγνωρίσιμη την ουσία του πρωτοτύπου.\",\"discover_prompt_text_cartoon\":\"Πάρε τη μεταφορτωμένη φωτογραφία μου και μετέτρεψέ με σε διασκεδαστικό χαρακτήρα κινουμένων σχεδίων. Ξαναφαντάσου την εμφάνισή μου σαν να ήμουν χαρακτήρας σε ταινία Pixar ή Disney — χρησιμοποίησε τολμηρά περιγράμματα, υπερβολικά αλλά κολακευτικά χαρακτηριστικά, ζωντανά χρώματα και εκφραστικό στυλ animation. Κράτησε αναγνωρίσιμη την ομοιότητά μου.\",\"discover_prompt_text_headshot\":\"Πάρε τη μεταφορτωμένη φωτογραφία μου και δημιούργησε ένα επαγγελματικό πορτρέτο για επαγγελματική χρήση. Βελτίωσε τον φωτισμό, όξυνε τις λεπτομέρειες, χρησιμοποίησε ένα καθαρό ουδέτερο ή ντεγκραντέ φόντο, εξασφάλισε επαγγελματικό ντύσιμο και στάση, και κάνε με να φαίνομαι κομψός και σίγουρος — σαν να με φωτογράφισε επαγγελματίας φωτογράφος πορτρέτων.\",\"discover_prompt_text_pet_royalty\":\"Πάρε τη μεταφορτωμένη φωτογραφία μου και ξαναφαντάσου το κατοικίδιό μου ως μέλος βασιλικής οικογένειας. Ντύσε το με βασιλική ενδυμασία όπως στέμμα, βασιλικό μανδύα και κοσμήματα. Τοποθέτησε το σε έναν πολυτελή θρόνο ή σε ένα μεγαλοπρεπές παλάτι. Κάνε το να μοιάζει με επίσημο βασιλικό πορτρέτο με δραματικό φωτισμό και πλούσιες, χλιδάτες λεπτομέρειες.\",\"discover_prompt_text_superhero\":\"Πάρε τη μεταφορτωμένη φωτογραφία μου και μετέτρεψέ με σε υπερήρωα. Δώσε μου μια μοναδική, πρωτότυπη στολή υπερήρωα με κάπα, μάσκα ή έμβλημα και ηρωικό σωματότυπο. Τοποθέτησε με σε δραματική δυναμική πόζα με αστικό τοπίο ή επικό φόντο. Πρόσθεσε οπτικά εφέ όπως αύρες ενέργειας, άνεμο ή δραματικό φωτισμό.\",\"discover_prompt_text_watercolor\":\"Πάρε τη μεταφορτωμένη φωτογραφία μου και μετέτρεψέ τη σε ένα πανέμορφο υδατογραφικό πίνακα. Χρησιμοποίησε απαλές, ρέουσες πινελιές υδατογραφίας, ήπιες χρωματικές μεταβάσεις, ημιδιάφανα στρώματα και τη χαρακτηριστική υφή χαρτιού της παραδοσιακής υδατογραφίας. Κράτησε τη σύνθεση αναγνωρίσιμη αλλά με καλλιτεχνική, ζωγραφισμένη στο χέρι ποιότητα.\",\"discover_prompt_text_action_figure\":\"Πάρε τη μεταφορτωμένη φωτογραφία μου και ξαναφαντάσου με ως συλλεκτική φιγούρα δράσης στη συσκευασία της. Δείξε με ως λεπτομερή φιγούρα δράσης με πλαστική υφή, αρθρωτές αρθρώσεις και αξεσουάρ. Συμπερίλαβε ρεαλιστική συσκευασία παιχνιδιού με διάφανο παράθυρο, πολύχρωμη κάρτα υποστήριξης και branding προϊόντος.\",\"ideas_chip_enhance\":\"Επαυξάνω\",\"ideas_chip_create_art\":\"Δημιουργώ\",\"ideas_chip_design\":\"Σχέδιο\",\"ideas_chip_swap_outfit\":\"Ανταλαγή\",\"ideas_chip_visualize\":\"Φαντάζομαι\",\"ideas_prompt_restore_photo\":\"μια παλιά φωτογραφία\",\"ideas_prompt_professional_headshot\":\"ένα πορτρέτο σε ένα headshot\",\"ideas_prompt_oil_painting\":\"φωτογραφία σε πίνακα ζωγραφικής\",\"ideas_prompt_colorize_photo\":\"μια έγχρωμη ασπρόμαυρη φωτογραφία\",\"ideas_prompt_cartoonize\":\"μια καρτούν εκδοχή μιας φωτογραφίας\",\"ideas_prompt_watercolor_painting\":\"μια ζωγραφιά\",\"ideas_prompt_tshirt_design\":\"ένα γραφικό μπλουζάκι\",\"ideas_prompt_cute_character\":\"μια χαριτωμένη εικονογράφηση χαρακτήρων\",\"ideas_prompt_business_logo\":\"ένα λογότυπο επιχείρησης\",\"ideas_prompt_event_flyer\":\"ένα φυλλάδιο εκδήλωσης\",\"ideas_prompt_sports_schedule\":\"ένα γραφικό αθλητικού προγράμματος\",\"ideas_prompt_social_media_ad\":\"μια διαφήμιση στα μέσα κοινωνικής δικτύωσης\",\"ideas_prompt_new_outfit\":\"μια στολή σε μια φωτογραφία\",\"ideas_prompt_swap_clothing\":\"ρούχα ανάμεσα σε δύο φωτογραφίες\",\"ideas_prompt_change_hairstyle\":\"ένα χτένισμα\",\"ideas_prompt_outfit_color\":\"χρώματα ρούχων\",\"ideas_prompt_restyle_room\":\"έναν επανασχεδιασμό δωματίου\",\"ideas_prompt_stage_room\":\"ένα άδειο δωμάτιο με έπιπλα\",\"ideas_prompt_house_extension\":\"μια επέκταση σπιτιού\",\"ideas_prompt_new_build\":\"νέο κτίριο εξωτερικά\",\"enhancer_headline\":\"Ανεβάστε μια φωτογραφία για βελτίωση και αναβάθμιση με AI\",\"enhancer_prompt_prefix\":\"Βελτίωση και αναβάθμιση της εικόνας μου.\",\"send_button_generate\":\"Δημιουργία\"},\"BackgroundLanding\":{\"hero_title\":\"Αφαίρεση φόντου με \u003caccent\u003eτεχνητή νοημοσύνη\u003c/accent\u003e\",\"hero_title_variant_b\":\"\u003caccent\u003eΑφαιρέστε\u003c/accent\u003e οποιοδήποτε φόντο σε δευτερόλεπτα\",\"hero_subtitle\":\"Ανεβάστε μια φωτογραφία και αποκτήστε ένα καθαρό, ακριβές αποκόμμα σε δευτερόλεπτα.\",\"social_proof_hd_download\":\"Λήψη HD\",\"social_proof_image_enhancer\":\"Βελτιωτής εικόνας\",\"social_proof_formats\":\"JPG, PNG, WEBP, HEIC\",\"social_proof_daily\":\"5M+ εικόνες δημιουργούνται καθημερινά\",\"showcase_title\":\"Φόντο αφαιρέθηκε, τι τώρα;\",\"showcase_swap\":\"Αλλαγή χρώματος\",\"showcase_transparent\":\"Διαφανές φόντο\",\"showcase_new_bg\":\"Νέο φόντο\",\"showcase_possibilities\":\"Ατελείωτες δυνατότητες\",\"features_heading\":\"Σχεδιασμένο για κάθε ροή εργασίας\",\"features_subtitle\":\"Από γρήγορες προσωπικές επεξεργασίες έως μεγάλης κλίμακας επαγγελματικές ροές.\",\"feature_for_individuals_title\":\"Για ιδιώτες\",\"feature_for_individuals_description\":\"Φωτογραφίες προφίλ, αναρτήσεις στα μέσα και προσωπικά έργα.\",\"feature_for_freelancers_title\":\"Για ελεύθερους επαγγελματίες\",\"feature_for_freelancers_description\":\"Παραδόσεις σε πελάτες, mockups και κομμάτια portfolio.\",\"feature_for_marketing_title\":\"Για μάρκετινγκ\",\"feature_for_marketing_description\":\"Στοιχεία καμπανιών, banners και διαφημιστικά σε κλίμακα.\",\"feature_for_developers_title\":\"Για προγραμματιστές\",\"feature_for_developers_description\":\"Ενσωμάτωση API για αυτοματοποιημένες ροές εικόνων.\",\"feature_for_ecommerce_title\":\"Για ηλεκτρονικό εμπόριο\",\"feature_for_ecommerce_description\":\"Καθαρές φωτογραφίες προϊόντων σε λευκό ή διαφανές φόντο.\",\"feature_for_enterprise_title\":\"Για επιχειρήσεις\",\"feature_for_enterprise_description\":\"Μαζική επεξεργασία με συνεπή, έτοιμη για brand έξοδο.\",\"before_after_heading\":\"Δείτε τη διαφορά\",\"before_after_subtitle\":\"Καθαρά, ακριβή αποκόμματα για ανθρώπους, προϊόντα, ζώα και άλλα.\",\"before_after_tab_people\":\"Άνθρωποι\",\"before_after_tab_products\":\"Προϊόντα\",\"before_after_tab_animals\":\"Ζώα\",\"before_after_tab_cars\":\"Αυτοκίνητα\",\"upload_click_or_drag\":\"Κάντε κλικ ή σύρετε μια εικόνα εδώ\",\"upload_unsupported_file_alert\":\"Υποστηρίζονται μόνο εικόνες JPG, PNG, WebP και HEIC.\",\"upload_formats\":\"JPG, JPEG, PNG, WEBP, HEIC\",\"upload_uploading\":\"Μεταφόρτωση...\",\"upload_starting\":\"Εκκίνηση...\",\"upload_remove_background\":\"Αφαίρεση φόντου\",\"upload_button\":\"Μεταφόρτωση εικόνας\",\"drop_image_anywhere\":\"Αφήστε την εικόνα οπουδήποτε\",\"background_removal_prompt\":\"Αφαιρέστε το φόντο από αυτή την εικόνα και κάντε το πλήρως διαφανές.\",\"toast_no_image_title\":\"Δεν προστέθηκε εικόνα\",\"toast_no_image_description\":\"Ανεβάστε μια εικόνα για να αφαιρέσετε το φόντο της.\",\"bg_removal_creation_hero_headline\":\"Ανεβάστε ή σύρετε την εικόνα σας για να αφαιρέσετε το φόντο σε πορτρέτα, προϊόντα, λογότυπα ή οτιδήποτε άλλο.\",\"bg_removal_creation_hero_headline_mobile\":\"Ανεβάστε την εικόνα σας για να αφαιρέσετε το φόντο σε πορτρέτα, προϊόντα, λογότυπα ή οτιδήποτε άλλο.\",\"bg_removal_input_placeholder\":\"Αφαίρεση φόντου από αυτή την εικόνα...\"},\"MessagePastedText\":{\"label_pasted\":\"Επικολλήθηκε\",\"label_characters\":\"χαρακτήρες\",\"pasted_content_title\":\"Επικολλημένο περιεχόμενο\",\"label_text\":\"Κείμενο\",\"label_click_to_edit\":\"Κάντε κλικ για επεξεργασία\",\"label_click_to_view\":\"Κάντε κλικ για προβολή\",\"label_changes_save_automatically\":\"Οι αλλαγές αποθηκεύονται αυτόματα κατά την επεξεργασία\"},\"AppsLanding\":{\"page_title\":\"Εφαρμογές\",\"page_subtitle\":\"Εξερευνήστε τα εργαλεία μας με τεχνητή νοημοσύνη\",\"image_generation_title\":\"Δημιουργία εικόνων\",\"image_generation_description\":\"Δημιουργήστε εντυπωσιακές εικόνες από κειμενικές περιγραφές με τεχνητή νοημοσύνη\",\"background_removal_title\":\"Αφαίρεση φόντου\",\"background_removal_description\":\"Αφαιρέστε το φόντο εικόνων σε δευτερόλεπτα με τεχνητή νοημοσύνη\",\"image_enhancer_title\":\"Βελτιωτής εικόνας\",\"image_enhancer_description\":\"Βελτιώστε και αναβαθμίστε τις φωτογραφίες σας σε υψηλότερη ανάλυση με AI\"},\"ChatExamples\":{\"email\":{\"title\":\"Βοηθήστε με να γράψω (παράδειγμα)\",\"user_1\":\"Πρέπει να γράψω ένα email στον διευθυντή μου ζητώντας άδεια τον επόμενο μήνα. Θέλω να ακούγεται επαγγελματικό αλλά όχι πολύ επίσημο. Να τι θέλω να πω: Χρειάζομαι 5 ημέρες άδεια από 10-14 Μαρτίου για μια οικογενειακή εκδήλωση.\",\"assistant_1\":\"Ακολουθεί μια γυαλισμένη έκδοση του αιτήματός σας για άδεια:\\n\\nΘέμα: Αίτημα αδείας - 10-14 Μαρτίου\\n\\nΓεια σας [Όνομα Διευθυντή],\\n\\nΕλπίζω να είσαι καλά. Θα ήθελα να ζητήσω άδεια από Δευτέρα 10 Μαρτίου έως Παρασκευή 14 Μαρτίου για μια οικογενειακή εκδήλωση.\\n\\nΘα βεβαιωθώ ότι όλες οι τρέχουσες εργασίες και οι προθεσμίες καλύπτονται πριν φύγω και είμαι στην ευχάριστη θέση να συντονίσω την παράδοση με την ομάδα.\\n\\nΠαρακαλώ ενημερώστε με εάν χρειάζεστε επιπλέον λεπτομέρειες.\\n\\nΜε εκτίμηση,\\n[Το όνομά σου]\\n\\n---\\n\\nΘέλετε να προσαρμόσω τον τόνο, να προσθέσω περισσότερο περιβάλλον ή να το συντομεύσω;\",\"user_2\":\"Μπορείτε να το κάνετε πιο σύντομο; Μόνο 2-3 προτάσεις.\",\"assistant_2\":\"Θέμα: Αίτημα αδείας - 10-14 Μαρτίου\\n\\nΓεια σας [Όνομα Διευθυντή],\\n\\nΘα ήθελα να ζητήσω άδεια από τις 10 έως τις 14 Μαρτίου για μια οικογενειακή εκδήλωση. Όλες οι τρέχουσες εργασίες θα καλυφθούν πριν φύγω. Ενημερώστε με αν χρειάζεστε κάτι άλλο.\\n\\nΤο καλύτερο,\\n[Το όνομά σου]\\n\\n---\\n\\nΓινώμενος. Θέλετε να προσαρμόσω κάτι άλλο;\"},\"logo\":{\"title\":\"Δημιουργήστε λογότυπο (παράδειγμα)\",\"user_1\":\"Ξεκινάω ένα μικρό καφενείο που ονομάζεται \\\"Πρωινό Τελετουργικό\\\" και χρειάζομαι ένα λογότυπο. Θέλω κάτι καθαρό και μοντέρνο, ίσως με εικονίδιο φλιτζανιού καφέ.\",\"prompt_1\":\"Καθαρό μοντέρνο λογότυπο για μια καφετέρια που ονομάζεται Morning Ritual, μίνιμαλ σιλουέτα φλιτζανιού καφέ με ατμό που σχηματίζει ένα διακριτικό μοτίβο ανατολής, σύγχρονη τυπογραφία sans-serif, ασπρόμαυρη\",\"assistant_1\":\"Εδώ είναι μια καθαρή, μοντέρνα ιδέα λογότυπου για το Morning Ritual. Διαθέτει μια μίνιμαλ σιλουέτα φλιτζάνι καφέ με τον ατμό να σχηματίζει ένα διακριτικό μοτίβο ανατολής. Η τυπογραφία χρησιμοποιεί μια σύγχρονη γραμματοσειρά sans-serif.\\n\\nΘέλετε να δοκιμάσω ένα διαφορετικό στυλ, να αλλάξω χρώματα ή να προσαρμόσω το εικονίδιο;\",\"user_2\":\"Μου αρέσει αλλά μπορείς να το δοκιμάσεις με γήινες αποχρώσεις; Καφέ και κρεμ αντί για μαύρο.\",\"prompt_2\":\"Καθαρό μοντέρνο λογότυπο για μια καφετέρια που ονομάζεται Morning Ritual, μίνιμαλ σιλουέτα φλιτζανιού καφέ με ατμό που σχηματίζει ένα διακριτικό μοτίβο ανατολής, σύγχρονη sans-serif τυπογραφία, γήινες αποχρώσεις, βαθύ καφέ εικονίδιο, πλούσιο κρεμ φόντο\",\"assistant_2\":\"Ακολουθεί η ενημερωμένη έκδοση με ζεστούς γήινους τόνους - βαθύ καφέ για το εικονίδιο και πλούσια κρέμα για το φόντο. Η ζεστή παλέτα του δίνει μια πιο φιλόξενη, χειροποίητη αίσθηση.\\n\\nΘέλετε να δημιουργήσω παραλλαγές, να προσθέσω ένα tagline ή να προετοιμάσω αρχεία για διαφορετικά μεγέθη;\"},\"resume\":{\"title\":\"Ελέγξτε το βιογραφικό μου (παράδειγμα)\",\"user_1\":\"Υποβάλλω αίτηση για θέση διευθυντή μάρκετινγκ. Μπορείτε να δείτε το βιογραφικό μου και να μου πείτε τι να βελτιώσω;\",\"assistant_1\":\"Εξέτασα το βιογραφικό σας. Εδώ είναι οι βασικοί τομείς για βελτίωση:\\n\\n- Η περίληψή σας είναι πολύ γενική. Θα πρέπει να αναφέρει τη συγκεκριμένη εμπειρία σας στο μάρκετινγκ και τα μετρήσιμα αποτελέσματα που επιτύχατε.\\n\\n- Η ενότητα εργασιακής εμπειρίας παραθέτει τις ευθύνες αλλά όχι τα αποτελέσματα. Για παράδειγμα, αντί για \\\"Διαχειριζόμενοι λογαριασμοί μέσων κοινωνικής δικτύωσης\\\", δοκιμάστε το \\\"Αύξηση της αφοσίωσης στα μέσα κοινωνικής δικτύωσης κατά 45% σε διάστημα 6 μηνών\\\".\\n\\n- Στην ενότητα Δεξιοτήτων λείπουν λέξεις-κλειδιά από τις τυπικές περιγραφές θέσεων εργασίας του υπεύθυνου μάρκετινγκ, όπως αναλυτικά στοιχεία καμπάνιας, διαχείριση προϋπολογισμού και δοκιμές A/B.\\n\\n- Η μορφοποίηση είναι καθαρή, αλλά ο πιο πρόσφατος ρόλος σας θα πρέπει να έχει περισσότερες λεπτομέρειες από παλαιότερες θέσεις.\\n\\nΘέλετε να ξαναγράψω την περίληψή σας ή να προτείνω πιο δυνατά σημεία για έναν συγκεκριμένο ρόλο;\",\"user_2\":\"Μπορείτε να μου ξαναγράψετε την περίληψη;\",\"assistant_2\":\"Ακολουθεί μια ενημερωμένη περίληψη με βάση το βιογραφικό σας:\\n\\n\\\"Επαγγελματίας μάρκετινγκ με 5ετή εμπειρία σε ψηφιακές καμπάνιες, στρατηγική περιεχομένου και ηγεσία ομάδας. Αποδεδειγμένο ιστορικό αυξανόμενης αφοσίωσης και αύξησης εσόδων μέσω πρωτοβουλιών μάρκετινγκ που βασίζονται σε δεδομένα. Εξειδίκευση στο SEO, τα επί πληρωμή μέσα, το μάρκετινγκ ηλεκτρονικού ταχυδρομείου και τη διαλειτουργική συνεργασία.\\\"\\n\\nΑυτή η έκδοση υπογραμμίζει την εμπειρία σας, αναφέρει συγκεκριμένες δεξιότητες και εστιάζει στα αποτελέσματα. Θέλετε να το προσαρμόσω για έναν διαφορετικό ρόλο ή να δουλέψω στη συνέχεια στα σημεία σας;\"}},\"Connectors\":{\"page_title\":\"Συνδέσεις\",\"page_subtitle\":\"Συνδέστε υπηρεσίες τρίτων με τον βοηθό AI σας\",\"mobile_subtitle\":\"Συνδέστε τα εργαλεία σας και διαχειριστείτε την πρόσβαση από ένα σημείο.\",\"desktop_heading\":\"Συνδέστε τα εργαλεία σας\",\"desktop_subheading\":\"Επιλέξτε ποιες εφαρμογές θα συνδέσετε και διαχειριστείτε την πρόσβαση για κάθε εργαλείο σε ένα μέρος.\",\"modal_heading\":\"Συνδέστε τα εργαλεία σας\",\"empty_state\":\"Επιλέξτε μια σύνδεση για να δείτε λεπτομέρειες\",\"back\":\"Πίσω\",\"connect\":\"Σύνδεση\",\"connecting\":\"Σύνδεση…\",\"disconnect\":\"Αποσύνδεση\",\"disconnecting\":\"Αποσύνδεση…\",\"connected\":\"Συνδεδεμένο\",\"disconnected\":\"Αποσυνδεδεμένο\",\"cancel\":\"Ακύρωση\",\"dismiss\":\"Κλείσιμο\",\"loading\":\"Φόρτωση συνδέσεων…\",\"load_failed\":\"Αποτυχία φόρτωσης συνδέσεων.\",\"connected_success\":\"Η σύνδεση ολοκληρώθηκε επιτυχώς.\",\"disconnected_success\":\"Η αποσύνδεση ολοκληρώθηκε επιτυχώς.\",\"connect_failed\":\"Αποτυχία σύνδεσης.\",\"disconnect_failed\":\"Αποτυχία αποσύνδεσης.\",\"connect_oauth_failed\":\"Δεν ήταν δυνατή η έναρξη της σύνδεσης. Δοκιμάστε ξανά.\",\"toast_connect_failed_named\":\"Αποτυχία σύνδεσης με {name}.\",\"toast_disconnect_success_named\":\"Αποσυνδεθήκατε από το {name}.\",\"toast_disconnect_failed_named\":\"Αποτυχία αποσύνδεσης από {name}.\",\"callback_connection_failed\":\"Η σύνδεση απέτυχε.\",\"badge_coming_soon\":\"Σύντομα\",\"badge_soon\":\"Σύντομα\",\"badge_tools_count\":\"{count} εργαλεία\",\"section_connected\":\"Συνδεδεμένα\",\"section_not_connected\":\"Μη συνδεδεμένα\",\"connected_services_title\":\"Συνδεδεμένες υπηρεσίες\",\"manage_connectors\":\"Διαχείριση συνδέσεων\",\"detail_tools_label\":\"Εργαλεία\",\"detail_details_label\":\"Λεπτομέρειες\",\"detail_version\":\"Έκδοση\",\"detail_provider\":\"Πάροχος\",\"detail_auth_type\":\"Τύπος ταυτοποίησης\",\"detail_access\":\"Πρόσβαση\",\"detail_tools_description\":\"Επιλέξτε πότε επιτρέπεται στο use.ai να χρησιμοποιεί αυτά τα εργαλεία\",\"detail_read_tools\":\"Εργαλεία μόνο ανάγνωσης\",\"detail_write_actions\":\"Ενέργειες εγγραφής\",\"disconnect_title\":\"Αποσύνδεση από {name};\",\"disconnect_description\":\"Είστε βέβαιοι ότι θέλετε να αποσυνδεθείτε από το {name}; Θα αφαιρεθεί η πρόσβαση σε όλα τα σχετικά εργαλεία.\",\"disconnect_aria\":\"Αποσύνδεση {name}\",\"sr_disconnect_title\":\"Αποσύνδεση σύνδεσης\",\"sr_disconnect_confirm\":\"Επιβεβαίωση αποσύνδεσης\",\"disconnect_confirm_title\":\"Αποσύνδεση Gmail;\",\"disconnect_confirm_descri